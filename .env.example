# Copy this file to .env.local and fill in your own Supabase project values.
# Find these in your Supabase project: Project Settings -> API.

# The "Project URL" from Supabase API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The "anon / public" key from Supabase API settings
# (Never put the "service_role" key here — that one must stay secret.)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

